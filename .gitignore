# ============================================================
# EDB-AI-Circular-System — .gitignore
# ============================================================

# ---- Python ------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/

# ---- Data & Output -----------------------------------------
# circulars.json is TRACKED — required for GitHub Pages hosting
# !circulars.json  ← do NOT add this back to ignore list
edb_data/
edb_data/pdfs/
*.json.bak

# ---- PDF cache (large, regenerable, not versioned) ---------
.edb_cache/

# ---- Debug HTML snapshots (dev only) -----------------------
debug_edb_GET.html
debug_edb_POST.html
debug_edb_info.txt

# ---- Secrets -----------------------------------------------
.env
.env.*
*.key
*_api_key*
openai_key.txt

# ---- macOS -------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- IDE / Editor ------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ---- Backup snapshots (governance, keep locally) ----------
dev/init_backup/

# ---- Logs --------------------------------------------------
*.log
logs/

# ---- Misc --------------------------------------------------
*.tmp
*.temp
.cache/
